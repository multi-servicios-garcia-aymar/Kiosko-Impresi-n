{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kiosko de Impresion",
  "version": "1.0.1",
  "identifier": "ec.network.nexo.kiosko",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Kiosko de Impresión",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "additionalBrowserArgs": "--disable-print-preview"
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' asset: tauri: https://*.supabase.co wss://*.supabase.co; connect-src 'self' https://*.supabase.co wss://*.supabase.co; img-src 'self' asset: tauri: data: blob: https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  }
}
